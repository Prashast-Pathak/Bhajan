{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bhajan.ournakshatra.com/schema/bhajan.json",
  "title": "Bhajan/Stotra/Chalisa Content Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "type",
    "deity",
    "language",
    "title_hindi",
    "title_roman",
    "title_english",
    "seo",
    "rights",
    "safety",
    "crosslinks",
    "verses"
  ],
  "properties": {
    "id": { "type": "string" },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9\\-]*$" },
    "type": { "type": "string", "enum": ["bhajan", "aarti", "stotra", "chalisa", "shloka", "prayer"] },
    "deity": { "type": "string" },
    "deity_color": { "type": "string" },
    "language": { "type": "string", "enum": ["hi", "sa", "en"] },
    "title_hindi": { "type": "string", "minLength": 2 },
    "title_roman": { "type": "string", "minLength": 2 },
    "title_english": { "type": "string", "minLength": 2 },
    "festival": { "type": "array", "items": { "type": "string" } },
    "occasion": { "type": "array", "items": { "type": "string" } },
    "timing": { "type": "array", "items": { "type": "string" } },
    "composer": { "type": "string" },
    "duration_minutes": { "type": "number" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "topics": { "type": "array", "items": { "type": "string" } },
    "story": { "type": "string" },
    "story_hindi": { "type": "string" },
    "significance": { "type": "string" },
    "significance_hindi": { "type": "string" },
    "benefits": { "type": "array", "items": { "type": "string" } },
    "when_to_sing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "time": { "type": "array", "items": { "type": "string" } },
        "occasion": { "type": "array", "items": { "type": "string" } }
      }
    },
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meta_title", "meta_description"],
      "properties": {
        "meta_title": { "type": "string", "minLength": 6 },
        "meta_description": { "type": "string", "minLength": 20, "maxLength": 200 },
        "keywords": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["license", "source"],
      "properties": {
        "license": { "type": "string", "enum": ["traditional", "original", "permission"] },
        "source": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disallow_beej"],
      "properties": {
        "disallow_beej": { "type": "boolean" }
      }
    },
    "crosslinks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["astrology_intents"],
      "properties": {
        "astrology_intents": { "type": "array", "items": { "type": "string" } }
      }
    },
    "verses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "lines"],
        "properties": {
          "type": { "type": "string" },
          "label_hindi": { "type": "string" },
          "label_english": { "type": "string" },
          "lines": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["hindi", "roman"],
              "properties": {
                "hindi": { "type": "string", "minLength": 1 },
                "roman": { "type": "string", "minLength": 1 },
                "hindi_meaning": { "type": "string" },
                "english": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}

